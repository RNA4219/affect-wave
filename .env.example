# API LLM (OpenAI-compatible Chat Completions)
API_LLM_BASE_URL=
API_LLM_API_KEY=
API_LLM_MODEL=
API_LLM_SYSTEM_PROMPT=You are a helpful assistant.

# llama.cpp Embeddings Server
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080
# Recommended: Qwen3-Embedding-0.6B-Q8_0
EMBEDDING_MODEL=Qwen3-Embedding-0.6B-Q8_0

# API Server Settings
API_HOST=127.0.0.1
API_PORT=8080

# Output Mode (wave or params)
AFFECT_OUTPUT_MODE=wave

# Discord Transport (reply_prefix or webhook)
DISCORD_TRANSPORT=reply_prefix

# Discord Bot (required for Discord adapter example)
DISCORD_BOT_TOKEN=

# Discord Webhook (optional, for webhook transport)
DISCORD_WEBHOOK_URL=

# State Logging
STATE_LOG_ENABLED=false
STATE_LOG_PATH=./logs/affect-state.jsonl

# Prototypes Directory
PROTOTYPES_DIR=./data/prototypes
